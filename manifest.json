{
  "manifest_version": 3,
  "name": "Random Steam Game",
  "version": "1.0",
  "description": "Picks a random game from your Steam library.",
  "action": {
    "default_icon": "hello_extensions.png"
  },
  "background": {
    "service_worker": "scripts/background-chrome.js"
  },
  "content_scripts": [
    {
      "js": [
        "scripts/content.js"
      ],
      "matches": [
        "https://steamcommunity.com/id/*/games*"
      ]
    }
  ]
}